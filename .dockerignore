# Ignore Python and OS bytecode files
*.pyc
*.pyo
__pycache__/
*.DS_Store
desktop.ini
autorun.ini


# Ignore Docker-related files
Dockerfile
dockerfile
compose.yml
compose.dev.yml
docker-compose.yml

# Ignore Git-related files
.git/
.github/
.gitignore
.gitattributes

# Ignore useless directories
logs/
media/
staticfiles/
imports/
.backups/
venv/
.venv/
dist/
*.egg-info/
build/
.proxy/
/docs/
.pytest*/
.ruff_cache/
/.sonar/
/scratch/
/tests/

# Ignore Celery-related files
celerybeat-*

# Ignore sensetive files and secrets
.env
.key
secrets.enc
start.sh
start.ps1
tracker.md
.secrets/
.xpose/
.agents
.claude
.codex
db.sqlite3