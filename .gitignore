# Ignore Python and OS bytecode files
**/__pycache__/
*.pyc
*.pyo
**/.DS_Store
desktop.ini
autorun.ini

# Ignore useless directories
/logs/
/media/
/staticfiles/
/imports/
/.backups/
/venv/
/.venv/
/dist/
*.egg-info/
/build/
/scratch/
.pytest*/
.ruff_cache/

# Ignore Celery-related files
celerybeat-*

# Ignore sensetive files and secrets
.env
.key
.secrets/
.xpose/
.agents
.claude
.codex
db.sqlite3